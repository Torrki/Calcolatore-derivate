digraph "NodoOperatore"
{
 // LATEX_PDF_SIZE
  bgcolor="transparent";
  edge [fontname=Helvetica,fontsize=10,labelfontname=Helvetica,labelfontsize=10];
  node [fontname=Helvetica,fontsize=10,shape=box,height=0.2,width=0.4];
  Node1 [id="Node000001",label="NodoOperatore",height=0.2,width=0.4,color="gray40", fillcolor="grey60", style="filled", fontcolor="black",tooltip="Nodo per rappresentare un operatore."];
  Node2 -> Node1 [id="edge1_Node000001_Node000002",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=" n1\nn2",fontcolor="grey" ];
  Node2 [id="Node000002",label="Nodo",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$unionNodo.html",tooltip="Unione per rappresentare il tipo generico del nodo."];
  Node3 -> Node2 [id="edge2_Node000002_Node000003",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=" nf",fontcolor="grey" ];
  Node3 [id="Node000003",label="NodoFunzione",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$structNodoFunzione.html",tooltip="Nodo per rappresentare una funzione."];
  Node1 -> Node2 [id="edge3_Node000002_Node000001",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=" no",fontcolor="grey" ];
}
